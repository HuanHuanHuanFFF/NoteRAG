APP_CONTAINER_NAME=noterag-app
APP_HOST_PORT=9000
SERVER_PORT=9000

POSTGRES_IMAGE=pgvector/pgvector:pg16
POSTGRES_CONTAINER_NAME=noterag-db
POSTGRES_HOST_PORT=5432
POSTGRES_DB=noterag
POSTGRES_USER=noterag
POSTGRES_PASSWORD=change-me

SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/noterag
SPRING_DATASOURCE_USERNAME=noterag
SPRING_DATASOURCE_PASSWORD=change-me

# Enable NoteRAG embedding in Docker/production. Set false only when running import/chunk without model calls.
NOTERAG_EMBEDDING_ENABLED=true
SPRING_AI_MODEL_CHAT=none
SPRING_AI_MODEL_EMBEDDING=openai
SPRING_AI_MODEL_IMAGE=none
SPRING_AI_MODEL_AUDIO_SPEECH=none
SPRING_AI_MODEL_AUDIO_TRANSCRIPTION=none
SPRING_AI_MODEL_MODERATION=none
SPRING_AI_OPENAI_API_KEY=
SPRING_AI_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
SPRING_AI_OPENAI_EMBEDDING_OPTIONS_MODEL=text-embedding-v4

# Embedding API batch parameters.
# DashScope text-embedding-v4 currently allows at most 10 inputs per request.
NOTERAG_EMBEDDING_BATCH_SIZE=10
NOTERAG_EMBEDDING_MAX_BATCH_SIZE=10

# Markdown chunking parameters.
NOTERAG_CHUNKING_MIN_TARGET_TOKENS=300
NOTERAG_CHUNKING_MAX_TARGET_TOKENS=800
NOTERAG_CHUNKING_HARD_MAX_TOKENS=1000
NOTERAG_CHUNKING_OVERLAP_CHARS=80

# Vector retrieval parameters.
NOTERAG_RETRIEVAL_DEFAULT_TOP_N=20
NOTERAG_RETRIEVAL_MAX_TOP_N=50

# Rerank parameters.
# NOTERAG_RERANK_ENABLED can stay false for local development; production should set it true.
# Rerank API key is independent from embedding/chat API keys.
NOTERAG_RERANK_ENABLED=false
NOTERAG_RERANK_PROVIDER=dashscope
NOTERAG_RERANK_MODEL=qwen3-rerank
NOTERAG_RERANK_API_KEY=
NOTERAG_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
NOTERAG_RERANK_DEFAULT_TOP_K=8
NOTERAG_RERANK_MAX_TOP_K=20
NOTERAG_RERANK_MAX_DOCUMENTS=500
NOTERAG_RERANK_INSTRUCT="给定一个技术问题，请从候选 Markdown 技术笔记片段中选出最能直接回答问题的正文片段。优先选择包含概念解释、机制说明、对比结论或操作要点的片段；降低只包含参考资料、链接列表、目录、图片说明、上下文不完整或不能直接回答问题的片段排名。"
