@baseUrl = http://localhost:9001
# Change resultSet to spring-ai-default when running against http://localhost:9001.
@resultSet = spring-ai
@resultDir = ./responses/compare/{{resultSet}}

### MySQL - relation database
POST {{baseUrl}}/api/retrieval/search
Content-Type: application/json
Accept: application/json

{
  "question": "什么是关系型数据库?",
  "topN": 10
}
>>! {{resultDir}}/01-relation-database.json

