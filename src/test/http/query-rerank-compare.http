@baseUrl = http://localhost:9000
@resultDir = ./responses/query-rerank-compare
@retrievalTopN = 20

### Query rerank - MyISAM vs InnoDB differences
# Expected: 200 OK
POST {{baseUrl}}/api/query
Content-Type: application/json
Accept: application/json

{
  "question": "MyISAM和InnoDB有什么区别?"
}
>>! {{resultDir}}/query-01-innodb-myisam-cn.json

### Retrieval only - MyISAM vs InnoDB differences
# Expected: 200 OK
POST {{baseUrl}}/api/retrieval/search
Content-Type: application/json
Accept: application/json

{
  "question": "MyISAM和InnoDB有什么区别?",
  "topN": {{retrievalTopN}}
}
>>! {{resultDir}}/retrieval-01-innodb-myisam-cn.json

